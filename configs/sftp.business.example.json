{
  "version": 1004,
  "receivers": {
    "rx_sftp": {
      "type": "sftp",
      "listen": "127.0.0.1:22",
      "selector": "sel_sftp",
      "match_key": {
        "mode": "filename"
      },
      "username": "demo",
      "password": "demo-pass",
      "remote_dir": "/incoming",
      "poll_interval_sec": 5,
      "chunk_size": 65536,
      "host_key_fingerprint": "SHA256:W5M5Qf3jQ8jD8I2LqzY9zT6QfPj1O9g3k8xw0Jm9r3A"
    }
  },
  "selectors": {
    "sel_sftp": {
      "matches": {
        "sftp|filename=orders.csv": "ts_file"
      },
      "default_task_set": "ts_file"
    }
  },
  "task_sets": {
    "ts_file": [
      "task_file"
    ]
  },
  "senders": {
    "tx_sftp": {
      "type": "sftp",
      "remote": "127.0.0.1:22",
      "username": "demo",
      "password": "demo-pass",
      "remote_dir": "/archive",
      "temp_suffix": ".tmp",
      "host_key_fingerprint": "SHA256:W5M5Qf3jQ8jD8I2LqzY9zT6QfPj1O9g3k8xw0Jm9r3A",
      "concurrency": 4
    },
    "tx_kafka": {
      "type": "kafka",
      "remote": "127.0.0.1:9092",
      "topic": "file-events",
      "partitioner": "hash_key",
      "record_key_source": "transfer_id"
    }
  },
  "pipelines": {
    "pipe_mark_file": [
      {
        "type": "mark_as_file_chunk",
        "path": "/archive/orders.bin",
        "bool": true
      }
    ],
    "pipe_clear_file": [
      {
        "type": "clear_file_meta"
      }
    ]
  },
  "tasks": {
    "task_file": {
      "execution_model": "channel",
      "channel_queue_size": 1024,
      "pipelines": [
        "pipe_mark_file",
        "pipe_clear_file"
      ],
      "senders": [
        "tx_sftp",
        "tx_kafka"
      ]
    }
  }
}
