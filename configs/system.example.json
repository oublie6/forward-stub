{
  "control": {
    "timeout_sec": 5,
    "config_watch_interval": "2s",
    "pprof_port": 6060
  },
  "logging": {
    "level": "info",
    "file": "",
    "max_size_mb": 100,
    "max_backups": 5,
    "max_age_days": 30,
    "compress": true,
    "traffic_stats_interval": "1s",
    "traffic_stats_sample_every": 1
  },
  "business_defaults": {
    "task": {
      "execution_model": "pool",
      "pool_size": 4096,
      "queue_size": 8192,
      "channel_queue_size": 8192,
      "payload_log_max_bytes": 256
    },
    "receiver": {
      "multicore": true,
      "num_event_loop": 8,
      "payload_log_max_bytes": 256
    },
    "sender": {
      "concurrency": 8
    }
  }
