{
  "version": 1003,
  "receivers": {
    "rx_kafka": {
      "type": "kafka",
      "listen": "127.0.0.1:9092",
      "selector": "sel_kafka",
      "match_key": {
        "mode": "topic"
      },
      "topic": "orders",
      "group_id": "forward-stub-orders",
      "client_id": "forward-stub-rx-orders",
      "dial_timeout": "10s",
      "conn_idle_timeout": "30s",
      "metadata_max_age": "5m",
      "retry_backoff": "250ms",
      "start_offset": "latest",
      "session_timeout": "45s",
      "heartbeat_interval": "3s",
      "rebalance_timeout": "1m",
      "balancers": [
        "range",
        "cooperative_sticky"
      ],
      "auto_commit": true,
      "auto_commit_interval": "5s",
      "fetch_min_bytes": 1,
      "fetch_max_bytes": 16777216,
      "fetch_max_partition_bytes": 1048576,
      "isolation_level": "read_uncommitted",
      "fetch_max_wait_ms": 100
    }
  },
  "selectors": {
    "sel_kafka": {
      "default_task_set": "ts_kafka"
    }
  },
  "task_sets": {
    "ts_kafka": [
      "task_kafka"
    ]
  },
  "senders": {
    "tx_kafka_hash": {
      "type": "kafka",
      "remote": "127.0.0.1:9092",
      "topic": "orders-out",
      "client_id": "forward-stub-tx-orders",
      "acks": "all",
      "idempotent": true,
      "retries": 20,
      "max_in_flight_requests_per_connection": 1,
      "dial_timeout": "10s",
      "request_timeout": "30s",
      "retry_timeout": "1m",
      "retry_backoff": "250ms",
      "conn_idle_timeout": "30s",
      "metadata_max_age": "5m",
      "linger_ms": 5,
      "batch_max_bytes": 1048576,
      "max_buffered_bytes": 4194304,
      "max_buffered_records": 5000,
      "compression": "zstd",
      "compression_level": 3,
      "partitioner": "hash_key",
      "record_key_source": "match_key",
      "concurrency": 8
    },
    "tx_kafka_fixed": {
      "type": "kafka",
      "remote": "127.0.0.1:9092",
      "topic": "orders-notify",
      "acks": 1,
      "idempotent": false,
      "retries": 3,
      "max_in_flight_requests_per_connection": 4,
      "compression": "gzip",
      "compression_level": 1,
      "partitioner": "round_robin",
      "record_key": "notify-fixed-key",
      "concurrency": 2
    }
  },
  "pipelines": {
    "pipe_route_notify": [
      {
        "type": "route_offset_bytes_sender",
        "offset": 0,
        "cases": {
          "01": "tx_kafka_hash"
        },
        "default_sender": "tx_kafka_fixed"
      }
    ]
  },
  "tasks": {
    "task_kafka": {
      "execution_model": "pool",
      "pool_size": 2048,
      "queue_size": 4096,
      "pipelines": [
        "pipe_route_notify"
      ],
      "senders": [
        "tx_kafka_hash",
        "tx_kafka_fixed"
      ]
    }
  }
}
