{
  "version": 1001,
  "receivers": {
    "rx_udp_ingress": {
      "type": "udp_gnet",
      "listen": "0.0.0.0:19000",
      "selector": "sel_ingress",
      "multicore": true,
      "num_event_loop": 8,
      "read_buffer_cap": 2097152,
      "socket_recv_buffer": 1073741824,
      "frame": "",
      "selector": "sel_ingress",
      "log_payload_recv": true,
      "payload_log_max_bytes": 128
    },
    "rx_tcp_ingress": {
      "type": "tcp_gnet",
      "listen": "0.0.0.0:19001",
      "multicore": true,
      "num_event_loop": 4,
      "read_buffer_cap": 1048576,
      "socket_recv_buffer": 1073741824,
      "frame": "u16be",
      "selector": "sel_ingress"
    },
    "rx_kafka_orders": {
      "type": "kafka",
      "listen": "127.0.0.1:9092,127.0.0.1:9093",
      "selector": "sel_kafka_orders",
      "topic": "orders",
      "group_id": "forward-stub-orders",
      "username": "demo",
      "password": "demo-pass",
      "sasl_mechanism": "PLAIN",
      "tls": true,
      "tls_skip_verify": false,
      "client_id": "forward-stub-rx-orders",
      "dial_timeout": "10s",
      "conn_idle_timeout": "30s",
      "metadata_max_age": "5m",
      "retry_backoff": "250ms",
      "start_offset": "earliest",
      "session_timeout": "45s",
      "heartbeat_interval": "3s",
      "rebalance_timeout": "1m",
      "balancers": [
        "cooperative_sticky"
      ],
      "auto_commit": true,
      "auto_commit_interval": "5s",
      "fetch_min_bytes": 1,
      "fetch_max_bytes": 16777216,
      "fetch_max_partition_bytes": 1048576,
      "isolation_level": "read_committed",
      "fetch_max_wait_ms": 100,
      "log_payload_recv": true,
      "payload_log_max_bytes": 512
    },
    "rx_sftp_input": {
      "type": "sftp",
      "listen": "127.0.0.1:22",
      "selector": "sel_sftp_input",
      "username": "demo",
      "password": "demo-pass",
      "remote_dir": "/input",
      "poll_interval_sec": 3,
      "chunk_size": 65536,
      "host_key_fingerprint": "SHA256:W5M5Qf3jQ8jD8I2LqzY9zT6QfPj1O9g3k8xw0Jm9r3A",
      "log_payload_recv": false
    }
  },
  "selectors": {
    "sel_ingress": {
      "matches": {
        "udp|src_addr=10.0.0.10:9000": "ts_realtime",
        "tcp|src_addr=10.0.0.10:9000": "ts_realtime",
        "udp|src_addr=10.0.0.11:9001": "ts_archive"
      },
      "default_task_set": "ts_realtime"
    },
    "sel_kafka_orders": {
      "matches": {
        "kafka|topic=orders|partition=0": "ts_orders_p0",
        "kafka|topic=orders|partition=1": "ts_orders_p1"
      },
      "default_task_set": "ts_orders_p0"
    },
    "sel_sftp_input": {
      "matches": {
        "sftp|remote_dir=/input|file_name=orders.csv": "ts_file_ingest",
        "sftp|remote_dir=/input|file_name=orders.done": "ts_file_notify"
      }
    }
  },
  "task_sets": {
    "ts_realtime": [
      "task_fast_udp",
      "task_pool_route"
    ],
    "ts_archive": [
      "task_channel_archive"
    ],
    "ts_orders_p0": [
      "task_order_normalize",
      "task_order_forward"
    ],
    "ts_orders_p1": [
      "task_order_normalize",
      "task_order_forward"
    ],
    "ts_file_ingest": [
      "task_mark_file",
      "task_send_sftp"
    ],
    "ts_file_notify": [
      "task_clear_file",
      "task_fixed_kafka"
    ]
  },
  "senders": {
    "tx_udp": {
      "type": "udp_unicast",
      "remote": "127.0.0.1:21000",
      "frame": "",
      "concurrency": 8,
      "socket_send_buffer": 1073741824,
      "local_ip": "0.0.0.0",
      "local_port": 20000
    },
    "tx_multicast": {
      "type": "udp_multicast",
      "remote": "239.10.10.10:22000",
      "frame": "",
      "concurrency": 4,
      "socket_send_buffer": 1073741824,
      "local_ip": "0.0.0.0",
      "local_port": 22001,
      "iface": "",
      "ttl": 1,
      "loop": false
    },
    "tx_tcp": {
      "type": "tcp_gnet",
      "remote": "127.0.0.1:21002",
      "frame": "u16be",
      "concurrency": 4,
      "socket_send_buffer": 1073741824
    },
    "tx_kafka_hash": {
      "type": "kafka",
      "remote": "127.0.0.1:9092,127.0.0.1:9093",
      "frame": "",
      "concurrency": 8,
      "socket_send_buffer": 1073741824,
      "topic": "output-topic",
      "username": "demo",
      "password": "demo-pass",
      "sasl_mechanism": "PLAIN",
      "tls": true,
      "tls_skip_verify": false,
      "client_id": "forward-stub-tx-hash",
      "dial_timeout": "10s",
      "request_timeout": "30s",
      "retry_timeout": "1m",
      "retry_backoff": "250ms",
      "conn_idle_timeout": "30s",
      "metadata_max_age": "5m",
      "acks": "all",
      "idempotent": true,
      "retries": 20,
      "max_in_flight_requests_per_connection": 1,
      "linger_ms": 5,
      "batch_max_bytes": 1048576,
      "max_buffered_bytes": 4194304,
      "max_buffered_records": 5000,
      "compression": "zstd",
      "compression_level": 3,
      "partitioner": "hash_key",
      "record_key_source": "match_key"
    },
    "tx_kafka_fixed": {
      "type": "kafka",
      "remote": "127.0.0.1:9092",
      "frame": "",
      "concurrency": 2,
      "socket_send_buffer": 1073741824,
      "topic": "notify-topic",
      "client_id": "forward-stub-tx-fixed",
      "acks": 1,
      "idempotent": false,
      "retries": 3,
      "max_in_flight_requests_per_connection": 4,
      "linger_ms": 1,
      "batch_max_bytes": 524288,
      "max_buffered_bytes": 1048576,
      "max_buffered_records": 1000,
      "compression": "gzip",
      "compression_level": 1,
      "partitioner": "round_robin",
      "record_key": "fixed-key"
    },
    "tx_sftp": {
      "type": "sftp",
      "remote": "127.0.0.1:22",
      "frame": "",
      "concurrency": 4,
      "socket_send_buffer": 1073741824,
      "username": "demo",
      "password": "demo-pass",
      "remote_dir": "/output",
      "temp_suffix": ".tmp",
      "host_key_fingerprint": "SHA256:W5M5Qf3jQ8jD8I2LqzY9zT6QfPj1O9g3k8xw0Jm9r3A"
    }
  },
  "pipelines": {
    "pipe_match_and_replace": [
      {
        "type": "match_offset_bytes",
        "offset": 0,
        "hex": "aabb"
      },
      {
        "type": "replace_offset_bytes",
        "offset": 2,
        "hex": "ccdd"
      }
    ],
    "pipe_route_sender": [
      {
        "type": "route_offset_bytes_sender",
        "offset": 0,
        "cases": {
          "01": "tx_udp",
          "02": "tx_tcp"
        },
        "default_sender": "tx_kafka_hash"
      }
    ],
    "pipe_mark_file": [
      {
        "type": "mark_as_file_chunk",
        "path": "/archive/orders.bin",
        "bool": true
      }
    ],
    "pipe_clear_file": [
      {
        "type": "clear_file_meta"
      }
    ]
  },
  "tasks": {
    "task_fast_udp": {
      "pool_size": 4096,
      "fast_path": true,
      "queue_size": 8192,
      "channel_queue_size": 8192,
      "pipelines": [
        "pipe_match_and_replace"
      ],
      "senders": [
        "tx_udp",
        "tx_multicast"
      ],
      "log_payload_send": true,
      "payload_log_max_bytes": 96
    },
    "task_pool_route": {
      "pool_size": 2048,
      "fast_path": false,
      "execution_model": "pool",
      "queue_size": 4096,
      "channel_queue_size": 4096,
      "pipelines": [
        "pipe_route_sender"
      ],
      "senders": [
        "tx_udp",
        "tx_tcp",
        "tx_kafka_hash"
      ],
      "log_payload_send": false
    },
    "task_channel_archive": {
      "pool_size": 1024,
      "execution_model": "channel",
      "queue_size": 2048,
      "channel_queue_size": 1024,
      "pipelines": [
        "pipe_match_and_replace"
      ],
      "senders": [
        "tx_sftp"
      ],
      "log_payload_send": true,
      "payload_log_max_bytes": 128
    },
    "task_order_normalize": {
      "execution_model": "pool",
      "pipelines": [
        "pipe_match_and_replace"
      ],
      "senders": [
        "tx_kafka_hash"
      ]
    },
    "task_order_forward": {
      "execution_model": "fastpath",
      "pipelines": [
        "pipe_route_sender"
      ],
      "senders": [
        "tx_udp",
        "tx_tcp",
        "tx_kafka_hash"
      ]
    },
    "task_mark_file": {
      "execution_model": "channel",
      "pipelines": [
        "pipe_mark_file"
      ],
      "senders": [
        "tx_sftp"
      ]
    },
    "task_send_sftp": {
      "execution_model": "channel",
      "pipelines": [],
      "senders": [
        "tx_sftp"
      ]
    },
    "task_clear_file": {
      "execution_model": "fastpath",
      "pipelines": [
        "pipe_clear_file"
      ],
      "senders": [
        "tx_sftp"
      ]
    },
    "task_fixed_kafka": {
      "execution_model": "fastpath",
      "pipelines": [],
      "senders": [
        "tx_kafka_fixed"
      ]
    }
  }
}
