{
  "version": 1001,
  "receivers": {
    "rx_udp_ingress": {
      "type": "udp_gnet",
      "listen": "0.0.0.0:19000",
      "selector": "sel_ingress",
      "multicore": true,
      "num_event_loop": 8,
      "socket_recv_buffer": 1073741824
    },
    "rx_tcp_ingress": {
      "type": "tcp_gnet",
      "listen": "0.0.0.0:19001",
      "selector": "sel_ingress",
      "frame": "u16be",
      "multicore": true,
      "num_event_loop": 4,
      "socket_recv_buffer": 1073741824
    },
    "rx_kafka_order": {
      "type": "kafka",
      "listen": "127.0.0.1:9092",
      "selector": "sel_kafka_order",
      "topic": "order",
      "group_id": "forward-stub-order",
      "client_id": "forward-stub-rx-order",
      "start_offset": "latest"
    },
    "rx_sftp_file": {
      "type": "sftp",
      "listen": "127.0.0.1:22",
      "selector": "sel_sftp_file",
      "username": "demo",
      "password": "demo",
      "remote_dir": "/input",
      "poll_interval_sec": 3,
      "chunk_size": 65536,
      "host_key_fingerprint": "SHA256:W5M5Qf3jQ8jD8I2LqzY9zT6QfPj1O9g3k8xw0Jm9r3A"
    }
  },
  "selectors": {
    "sel_ingress": {
      "matches": {
        "udp|src_addr=10.0.0.10:9000": "ts_realtime_forward",
        "tcp|src_addr=10.0.0.10:9000": "ts_realtime_forward",
        "udp|src_addr=10.0.0.11:9001": "ts_archive_forward"
      },
      "default_task_set": "ts_realtime_forward"
    },
    "sel_kafka_order": {
      "matches": {
        "kafka|topic=order|partition=0": "ts_order_partition_0",
        "kafka|topic=order|partition=1": "ts_order_partition_1"
      },
      "default_task_set": "ts_order_partition_0"
    },
    "sel_sftp_file": {
      "matches": {
        "sftp|remote_dir=/input|file_name=orders.csv": "ts_file_ingest",
        "sftp|remote_dir=/input|file_name=orders.done": "ts_file_notify"
      }
    }
  },
  "task_sets": {
    "ts_realtime_forward": ["task_parse", "task_route_sender"],
    "ts_archive_forward": ["task_archive"],
    "ts_order_partition_0": ["task_order_normalize", "task_order_forward"],
    "ts_order_partition_1": ["task_order_normalize", "task_order_forward"],
    "ts_file_ingest": ["task_mark_file", "task_send_sftp"],
    "ts_file_notify": ["task_clear_file", "task_notify_kafka"]
  },
  "senders": {
    "tx_udp": {
      "type": "udp_unicast",
      "local_ip": "0.0.0.0",
      "local_port": 20000,
      "remote": "127.0.0.1:21000",
      "concurrency": 8,
      "socket_send_buffer": 1073741824
    },
    "tx_tcp": {
      "type": "tcp_gnet",
      "remote": "127.0.0.1:21002",
      "frame": "u16be",
      "concurrency": 4,
      "socket_send_buffer": 1073741824
    },
    "tx_kafka": {
      "type": "kafka",
      "remote": "127.0.0.1:9092",
      "topic": "output-topic",
      "client_id": "forward-stub-tx",
      "acks": "all",
      "idempotent": true,
      "retries": 20,
      "max_in_flight_requests_per_connection": 1
    },
    "tx_sftp": {
      "type": "sftp",
      "remote": "127.0.0.1:22",
      "username": "demo",
      "password": "demo",
      "remote_dir": "/output",
      "temp_suffix": ".tmp",
      "host_key_fingerprint": "SHA256:W5M5Qf3jQ8jD8I2LqzY9zT6QfPj1O9g3k8xw0Jm9r3A"
    }
  },
  "pipelines": {
    "pipe_match_replace": [
      {"type": "match_offset_bytes", "offset": 0, "hex": "aabb"},
      {"type": "replace_offset_bytes", "offset": 2, "hex": "ccdd"}
    ],
    "pipe_route_sender": [
      {
        "type": "route_offset_bytes_sender",
        "offset": 0,
        "cases": {
          "01": "tx_udp",
          "02": "tx_tcp"
        },
        "default_sender": "tx_kafka"
      }
    ],
    "pipe_mark_file": [
      {"type": "mark_as_file_chunk", "path": "/archive/orders.bin", "bool": true}
    ],
    "pipe_clear_file": [
      {"type": "clear_file_meta"}
    ]
  },
  "tasks": {
    "task_parse": {
      "pipelines": ["pipe_match_replace"],
      "senders": ["tx_udp"],
      "execution_model": "fastpath"
    },
    "task_route_sender": {
      "pipelines": ["pipe_route_sender"],
      "senders": ["tx_udp", "tx_tcp", "tx_kafka"],
      "execution_model": "pool",
      "pool_size": 2048,
      "queue_size": 4096
    },
    "task_archive": {
      "pipelines": ["pipe_match_replace"],
      "senders": ["tx_sftp"],
      "execution_model": "channel",
      "channel_queue_size": 1024
    },
    "task_order_normalize": {
      "pipelines": ["pipe_match_replace"],
      "senders": ["tx_kafka"],
      "execution_model": "pool"
    },
    "task_order_forward": {
      "pipelines": ["pipe_route_sender"],
      "senders": ["tx_udp", "tx_kafka"],
      "execution_model": "fastpath"
    },
    "task_mark_file": {
      "pipelines": ["pipe_mark_file"],
      "senders": ["tx_sftp"],
      "execution_model": "channel"
    },
    "task_send_sftp": {
      "pipelines": [],
      "senders": ["tx_sftp"],
      "execution_model": "channel"
    },
    "task_clear_file": {
      "pipelines": ["pipe_clear_file"],
      "senders": ["tx_sftp"],
      "execution_model": "fastpath"
    },
    "task_notify_kafka": {
      "pipelines": [],
      "senders": ["tx_kafka"],
      "execution_model": "fastpath"
    }
  }
}
