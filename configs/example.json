{
  "version": 5,
  "control": {
    "api": "",
    "timeout_sec": 5,
    "config_watch_interval": "2s"
  },
  "receivers": {
    "udp_in": {
      "type": "udp_gnet",
      "listen": "udp://0.0.0.0:9000",
      "multicore": true,
      "num_event_loop": 0,
      "read_buffer_cap": 0,
      "frame": "",
      "log_payload_recv": true,
      "payload_log_max_bytes": 128
    },
    "udp_in2": {
      "type": "udp_gnet",
      "listen": "udp://0.0.0.0:9001",
      "multicore": true,
      "frame": ""
    }
  },
  "senders": {
    "udp_uni_out": {
      "type": "udp_unicast",
      "remote": "127.0.0.1:9100",
      "local_ip": "0.0.0.0",
      "local_port": 50000,
      "concurrency": 1
    },
    "udp_uni_out2": {
      "type": "udp_unicast",
      "remote": "127.0.0.1:9101",
      "local_ip": "0.0.0.0",
      "local_port": 50000,
      "concurrency": 1
    }
  },
  "pipelines": {
    "p1": [
      {
        "type": "match_offset_bytes",
        "offset": 0,
        "hex": "AABB"
      }
    ]
  },
  "tasks": {
    "udp_task_unicast": {
      "pool_size": 64,
      "queue_size": 256,
      "fast_path": false,
      "receivers": [
        "udp_in"
      ],
      "pipelines": [],
      "senders": [
        "udp_uni_out"
      ],
      "log_payload_send": true,
      "payload_log_max_bytes": 128
    },
    "udp_task_multicast": {
      "pool_size": 64,
      "queue_size": 256,
      "fast_path": false,
      "receivers": [
        "udp_in2"
      ],
      "pipelines": [],
      "senders": [
        "udp_uni_out2"
      ]
    }
  },
  "logging": {
    "level": "info",
    "file": "",
    "traffic_stats_interval": "5s",
    "traffic_stats_sample_every": 1,
    "compress": true,
    "max_size_mb": 100,
    "max_backups": 5,
    "max_age_days": 30,
    "payload_log_max_bytes": 128
  }
}
