{
  "version": 1001,
  "control": {
    "api": "",
    "timeout_sec": 5,
    "config_watch_interval": "2s",
    "pprof_port": 6060
  },
  "logging": {
    "level": "info",
    "file": "",
    "max_size_mb": 100,
    "max_backups": 5,
    "max_age_days": 30,
    "compress": true,
    "traffic_stats_interval": "1s",
    "traffic_stats_sample_every": 1,
    "payload_log_max_bytes": 256,
    "payload_pool_max_cached_bytes": 0,
    "gc_stats_log_enabled": false,
    "gc_stats_log_interval": "1m"
  },
  "receivers": {
    "rx_udp": {
      "type": "udp_gnet",
      "listen": "0.0.0.0:19000",
      "selector": "sel_ingress",
      "multicore": true,
      "num_event_loop": 8,
      "socket_recv_buffer": 1073741824
    },
    "rx_kafka": {
      "type": "kafka",
      "listen": "127.0.0.1:9092",
      "selector": "sel_kafka",
      "topic": "input-topic",
      "group_id": "forward-stub-group",
      "start_offset": "latest"
    }
  },
  "selectors": {
    "sel_ingress": {
      "matches": {
        "udp|src_addr=10.0.0.10:9000": "ts_realtime",
        "udp|src_addr=10.0.0.11:9001": "ts_archive"
      },
      "default_task_set": "ts_realtime"
    },
    "sel_kafka": {
      "matches": {
        "kafka|topic=input-topic|partition=0": "ts_realtime",
        "kafka|topic=input-topic|partition=1": "ts_archive"
      },
      "default_task_set": "ts_realtime"
    }
  },
  "task_sets": {
    "ts_realtime": [
      "task_forward",
      "task_notify"
    ],
    "ts_archive": [
      "task_archive"
    ]
  },
  "senders": {
    "tx_udp": {
      "type": "udp_unicast",
      "local_ip": "0.0.0.0",
      "local_port": 20000,
      "remote": "127.0.0.1:21000",
      "concurrency": 8,
      "socket_send_buffer": 1073741824
    },
    "tx_kafka": {
      "type": "kafka",
      "remote": "127.0.0.1:9092",
      "topic": "output-topic",
      "client_id": "forward-stub-tx",
      "acks": "all",
      "idempotent": true,
      "retries": 20,
      "max_in_flight_requests_per_connection": 1
    }
  },
  "pipelines": {
    "pipe_replace": [
      {
        "type": "replace_offset_bytes",
        "offset": 0,
        "hex": "aabb"
      }
    ]
  },
  "tasks": {
    "task_forward": {
      "pipelines": [
        "pipe_replace"
      ],
      "senders": [
        "tx_udp"
      ],
      "execution_model": "fastpath"
    },
    "task_notify": {
      "pipelines": [],
      "senders": [
        "tx_kafka"
      ],
      "execution_model": "fastpath"
    },
    "task_archive": {
      "pipelines": [
        "pipe_replace"
      ],
      "senders": [
        "tx_kafka"
      ],
      "execution_model": "channel",
      "channel_queue_size": 1024
    }
  }
}
