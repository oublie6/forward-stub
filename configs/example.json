{
  "version": 6,
  "control": {
    "api": "",
    "timeout_sec": 5
  },
  "runtime": {
    "default_task_pool_size": 64,
    "payload_pool_size": 1024,
    "payload_max_reuse_bytes": 0
  },
  "receivers": {
    "udp_in_for_udp_to_udp": {
      "type": "udp_gnet",
      "listen": "udp://0.0.0.0:9000",
      "multicore": true,
      "frame": ""
    },
    "udp_in_for_udp_to_kafka": {
      "type": "udp_gnet",
      "listen": "udp://0.0.0.0:9001",
      "multicore": true,
      "frame": ""
    },
    "kafka_in_for_kafka_to_udp": {
      "type": "kafka",
      "listen": "127.0.0.1:9092",
      "topic": "forward.stub.input",
      "group_id": "forward-stub-demo",
      "start_offset": "latest",
      "client_id": "forward-stub-recv"
    }
  },
  "senders": {
    "udp_out_for_udp_to_udp": {
      "type": "udp_unicast",
      "remote": "127.0.0.1:9100",
      "local_ip": "0.0.0.0",
      "local_port": 9200,
      "concurrency": 1
    },
    "kafka_out_for_udp_to_kafka": {
      "type": "kafka",
      "remote": "127.0.0.1:9092",
      "topic": "forward.stub.output",
      "concurrency": 1,
      "tls": false,
      "tls_skip_verify": false,
      "client_id": "forward-stub-send",
      "acks": -1,
      "linger_ms": 1,
      "batch_max_bytes": 1048576,
      "compression": "none",
      "send_timeout_ms": 5000
    },
    "udp_out_for_kafka_to_udp": {
      "type": "udp_unicast",
      "remote": "127.0.0.1:9101",
      "local_ip": "0.0.0.0",
      "local_port": 9201,
      "concurrency": 1
    }
  },
  "pipelines": {},
  "tasks": {
    "udp_to_udp": {
      "pool_size": 0,
      "fast_path": false,
      "receivers": [
        "udp_in_for_udp_to_udp"
      ],
      "pipelines": [],
      "senders": [
        "udp_out_for_udp_to_udp"
      ]
    },
    "udp_to_kafka": {
      "pool_size": 0,
      "fast_path": false,
      "receivers": [
        "udp_in_for_udp_to_kafka"
      ],
      "pipelines": [],
      "senders": [
        "kafka_out_for_udp_to_kafka"
      ]
    },
    "kafka_to_udp": {
      "pool_size": 0,
      "fast_path": false,
      "receivers": [
        "kafka_in_for_kafka_to_udp"
      ],
      "pipelines": [],
      "senders": [
        "udp_out_for_kafka_to_udp"
      ]
    }
  },
  "logging": {
    "level": "info",
    "file": "",
    "traffic_stats_interval": "5s",
    "traffic_stats_sample_every": 1,
    "traffic_stats_enable_sender": true
  },
  "pprof": {
    "enabled": false,
    "listen": "127.0.0.1:6060"
  }
}
