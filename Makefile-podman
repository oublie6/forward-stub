# Podman 版本入口，与 Makefile 的 deploy/docker 主线保持一致。

APP_NAME ?= forward-stub
GOFLAGS ?= -mod=vendor
PODMAN_BIN ?= podman

.PHONY: test vet clean build-skydds \
	podman-build-skydds-base podman-load-skydds-base \
	podman-build-skydds-runtime podman-load-skydds-runtime

test:
	GOFLAGS="$(GOFLAGS)" go test ./...

vet:
	GOFLAGS="$(GOFLAGS)" go vet ./...

clean:
	rm -rf bin dist

build-skydds:
	bash -c 'set -euo pipefail; source scripts/skydds/env.sh; CGO_ENABLED=1 GOFLAGS="$(GOFLAGS)" go build -trimpath -tags skydds -o bin/$(APP_NAME) .'

podman-build-skydds-base:
	DOCKER_BIN="$(PODMAN_BIN)" ./deploy/docker/build-and-save-base-ubuntu1804.sh

podman-load-skydds-base:
	DOCKER_BIN="$(PODMAN_BIN)" ./deploy/docker/load-base-ubuntu1804.sh

podman-build-skydds-runtime:
	DOCKER_BIN="$(PODMAN_BIN)" ./deploy/docker/build-and-save-skydds-runtime-ubuntu1804.sh

podman-load-skydds-runtime:
	DOCKER_BIN="$(PODMAN_BIN)" ./deploy/docker/load-skydds-runtime-ubuntu1804.sh
